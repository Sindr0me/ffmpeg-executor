# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://executor:${DB_PASSWORD}@postgres:5432/executor

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── S3 / Cloudflare R2 ────────────────────────────────────────────────────────
# For Cloudflare R2:
#   S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# For AWS S3:
#   S3_ENDPOINT_URL=   (leave empty)
S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_BUCKET=ffmpeg-executor-results
S3_ACCESS_KEY=your_r2_access_key_id
S3_SECRET_KEY=your_r2_secret_access_key
S3_OUTPUT_PREFIX=ffmpeg-results
S3_REGION=auto

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ── FFmpeg ────────────────────────────────────────────────────────────────────
FFMPEG_MAX_RUN_SECONDS=600
FFMPEG_WORK_DIR=/work

# ── API ───────────────────────────────────────────────────────────────────────
DEBUG=false
